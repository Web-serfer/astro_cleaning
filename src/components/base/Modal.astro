<div id="booking-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-white/30 backdrop-blur-sm hidden">
  <div class="relative w-full max-w-md bg-white/80 backdrop-blur-xl rounded-xl shadow-xl overflow-hidden border border-white/20">
    <!-- Заголовок модального окна -->
    <div class="p-6 border-b border-gray-200 flex justify-between items-center">
      <h3 class="text-xl font-bold text-gray-800">Book a Cleaning Service</h3>
      <button 
        id="close-modal-btn"
        class="p-1 rounded-full text-gray-700 hover:text-[var(--primary)] border border-gray-300 hover:border-[var(--primary)] transition-all duration-300 cursor-pointer hover:cursor-pointer"
        aria-label="Закрыть модальное окно"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- Форма в модальном окне -->
    <form id="booking-form" class="p-6">
      <div class="space-y-4">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-[var(--primary)] focus:border-[var(--primary)] transition-colors duration-300" 
            placeholder="Enter your name"
            required
          />
        </div>
        
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-[var(--primary)] focus:border-[var(--primary)] transition-colors duration-300" 
            placeholder="Enter your email"
            required
          />
        </div>
        
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-[var(--primary)] focus:border-[var(--primary)] transition-colors duration-300" 
            placeholder="Enter your phone number"
            required
          />
        </div>
        
        <div>
          <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Type</label>
          <select 
            id="service" 
            name="service" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-[var(--primary)] focus:border-[var(--primary)] transition-colors duration-300"
            required
          >
            <option value="">Select a service</option>
            <option value="regular">Regular Cleaning</option>
            <option value="deep">Deep Cleaning</option>
            <option value="move">Move-Out/Move-In</option>
            <option value="post">Post-Construction</option>
          </select>
        </div>
        
        <div>
          <label for="date" class="block text-sm font-medium text-gray-700 mb-1">Preferred Date</label>
          <input 
            type="date" 
            id="date" 
            name="date" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-[var(--primary)] focus:border-[var(--primary)] transition-colors duration-300" 
            required
          />
        </div>
        
        <div>
          <label for="time" class="block text-sm font-medium text-gray-700 mb-1">Preferred Time</label>
          <input 
            type="time" 
            id="time" 
            name="time" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-[var(--primary)] focus:border-[var(--primary)] transition-colors duration-300" 
            required
          />
        </div>
        
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Additional Information</label>
          <textarea 
            id="message" 
            name="message" 
            rows="3" 
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-[var(--primary)] focus:border-[var(--primary)] transition-colors duration-300" 
            placeholder="Any specific requirements?"
          ></textarea>
        </div>
      </div>
      
      <div class="mt-6">
        <button 
          type="submit"
          class="w-full py-3 px-4 bg-[var(--primary)] hover:bg-[var(--primary-hover)] text-white font-medium rounded-lg transition-colors duration-300"
        >
          Submit Request
        </button>
      </div>
    </form>
  </div>
</div>

<script is:inline>
  // Глобальные функции для открытия/закрытия модального окна
  window.openModal = function() {
    const modal = document.getElementById('booking-modal');
    if (modal) {
      modal.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    }
  };
  
  window.closeModal = function() {
    const modal = document.getElementById('booking-modal');
    if (modal) {
      modal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    }
  };
  
  document.addEventListener('DOMContentLoaded', () => {
    const closeModalBtn = document.getElementById('close-modal-btn');
    const modal = document.getElementById('booking-modal');
    
    if (closeModalBtn) {
      closeModalBtn.addEventListener('click', window.closeModal);
    }
    
    // Закрытие модального окна при клике вне его области
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          window.closeModal();
        }
      });
    }
    
    // Обработка отправки формы
    const form = document.getElementById('booking-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Получение данных формы
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // Здесь можно реализовать отправку данных на сервер
        console.log('Form data:', data);
        
        // Показ уведомления об успешной отправке
        alert('Your request has been submitted successfully!');
        
        // Закрытие модального окна
        window.closeModal();
        
        // Сброс формы
        form.reset();
      });
    }
    
    // Обработка события закрытия модального окна через ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        window.closeModal();
      }
    });
  });
</script>

<style is:inline>
  #booking-modal {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
</style>