---
import { Icon } from 'astro-icon/components';

interface Props {
    href?: string;
    text?: string;
    class?: string;
}

// Задаем значения по умолчанию
const { href = '#', text = 'BOOK NOW', class: className } = Astro.props;
---

<a href={href} class:list={['book-button', className]}>
    <!-- Иконка через Astro Icon -->
    <Icon name="bounding-box" class="icon" />

    <!-- Текст кнопки -->
    <span>{text}</span>
</a>

<style>
    .book-button {
        /* Расположение иконки и текста */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px; /* Расстояние между иконкой и текстом */

        /* Внешний вид */
        background-color: var(--primary); /* Фиолетовый цвет, как на картинке */
        color: #ffffff; /* Белый цвет текста и иконки */
        border: none;
        border-radius: 50px; /* Создает форму "пилюли" */
        padding: 10px 20px; /* Внутренние отступы */

        /* Стили текста */
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        text-transform: uppercase; /* Все буквы заглавные */
        letter-spacing: 0.5px;

        /* Прочее */
        text-decoration: none; /* Убираем подчеркивание у ссылки */
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }

    .book-button:hover {
        background-color: var(--primary-hover); /* Делаем цвет темнее при наведении */
        transform: translateY(-2px); /* Легкий эффект "подъема" */
    }

    /* SVG иконка наследует цвет от родителя благодаря `stroke="currentColor"` */
    .book-button .icon {
        /* Можно задать дополнительные стили для иконки, если нужно */
    }
</style>