---
// src/components/Button.astro

// Определяем свойства (props), которые компонент может принимать
// 'href' - ссылка, куда ведет кнопка
// 'text' - текст на кнопке
// 'className' - для добавления дополнительных CSS классов извне
interface Props {
    href?: string;
    text?: string;
    class?: string;
}

// Задаем значения по умолчанию
const { href = '#', text = 'BOOK NOW', class: className } = Astro.props;
---

<a href={href} class:list={['book-button', className]}>
    <!-- Иконка в формате SVG. Она легко стилизуется через CSS -->
    <svg
            class="icon"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
    >
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <rect x="4" y="4" width="16" height="16" rx="2"></rect>
        <circle cx="8.5" cy="8.5" r=".5" fill="currentColor"></circle>
        <circle cx="15.5" cy="8.5" r=".5" fill="currentColor"></circle>
        <circle cx="8.5" cy="15.5" r=".5" fill="currentColor"></circle>
        <circle cx="15.5" cy="15.5" r=".5" fill="currentColor"></circle>
    </svg>

    <!-- Текст кнопки -->
    <span>{text}</span>
</a>

<style>
    .book-button {
        /* Расположение иконки и текста */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px; /* Расстояние между иконкой и текстом */

        /* Внешний вид */
        background-color: #5d3ebc; /* Фиолетовый цвет, как на картинке */
        color: #ffffff; /* Белый цвет текста и иконки */
        border: none;
        border-radius: 50px; /* Создает форму "пилюли" */
        padding: 10px 26px; /* Внутренние отступы */

        /* Стили текста */
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        text-transform: uppercase; /* Все буквы заглавные */
        letter-spacing: 0.5px;

        /* Прочее */
        text-decoration: none; /* Убираем подчеркивание у ссылки */
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }

    .book-button:hover {
        background-color: #4a309a; /* Делаем цвет темнее при наведении */
        transform: translateY(-2px); /* Легкий эффект "подъема" */
    }

    /* SVG иконка наследует цвет от родителя благодаря `stroke="currentColor"` */
    .book-button .icon {
        /* Можно задать дополнительные стили для иконки, если нужно */
    }
</style>
