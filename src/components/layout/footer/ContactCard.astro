---
interface Props {
  title: string
  description: string
}

const { title, description } = Astro.props
---

<div class="flex flex-col items-center text-center gap-4 p-4">
    <div class="w-20 h-20 bg-white rounded-full mb-4"></div>
    <h3 class="text-2xl font-bold text-slate-800">{title}</h3>
    <p class="text-gray-600 max-w-[250px]">{description}</p>
    <div class="mt-4 font-semibold text-slate-800">
        <slot />
    </div>
</div>
