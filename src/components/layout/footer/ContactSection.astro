---
import ContactCard from './ContactCard.astro';
import { Icon } from 'astro-icon/components';
---

<section class="relative bg-[#e6efee] py-24 px-8 text-center" style="padding-bottom: 30rem;">
    <div class="max-w-7xl mx-auto">
        <span class="inline-block bg-white/70 py-2 px-5 rounded-full text-sm font-medium text-gray-700">Get in Touch</span>
        <h2 class="text-5xl font-extrabold my-6 text-slate-900">Have a Questions?</h2>
        <p class="max-w-2xl mx-auto mb-16 text-gray-600 leading-relaxed">
            Lorem ipsum dolor sit amet consectetur. Turpis pellentesque pellentesque tristique
            condimentum nulla eget. Tincidunt et vel ultrices viverra consequat neque
            aliquet vulputate.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <ContactCard title="E-Mail us" description="Lorem ipsum dolor sit amet consectetur.">
                <a href="mailto:wellknowncleaning@test.com" class="hover:underline">
                    wellknowncleaning@test.com
                </a>
            </ContactCard>

            <ContactCard title="Fill Out Form" description="Lorem ipsum dolor sit amet consectetur.">
                <button class="font-medium text-white hover:text-white relative inline-block px-6 py-3 bg-[var(--primary)] hover:bg-[var(--primary-hover)] rounded-full transition-all duration-300 hover:-translate-y-1 overflow-hidden cursor-pointer hover:cursor-pointer">
                    <span class="relative z-10 flex items-center gap-2">
                        <Icon name="bounding-box" class="icon w-4 h-4" />
                        REQUEST SOMETHING
                    </span>
                </button>
            </ContactCard>

            <ContactCard title="Phone us" description="Lorem ipsum dolor sit amet consectetur.">
                <a href="tel:2155550199" class="hover:underline">
                    (215) 555-0199
                </a>
            </ContactCard>
        </div>
    </div>
</section>
