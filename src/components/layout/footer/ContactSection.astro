---
import { Icon } from 'astro-icon/components';
import ContactCard from './ContactCard.astro';

const contactOptions = [
  {
    title: 'E-Mail us',
    description:
      "Send us an email with your inquiry and we'll get back to you shortly.",
    type: 'email',
    value: 'info@wellknowncleaning.com',
    href: 'mailto:info@wellknowncleaning.com',
  },
  {
    title: 'Request Service',
    description:
      "Fill out our service request form and we'll contact you to schedule a cleaning.",
    type: 'button',
    text: 'REQUEST SERVICE',
  },
  {
    title: 'Call us',
    description:
      'Speak directly with our customer service team for immediate assistance.',
    type: 'tel',
    value: '(215) 555-0199',
    href: 'tel:2155550199',
  },
]
---

<section class="relative bg-[#e6efee] py-24 px-8 text-center" style="padding-bottom: 30rem;">
    <div class="max-w-7xl mx-auto mb-8">
        <span class="inline-block bg-white/70 py-2 px-5 rounded-full text-sm font-medium text-gray-700">Get in Touch</span>
        <h2 class="text-5xl font-extrabold my-6 text-slate-900">Have a Questions?</h2>
        <p class="max-w-2xl mx-auto mb-16 text-gray-600 leading-relaxed">
            Reach out to us for any inquiries or to schedule our professional cleaning services. 
            We're available 24/7 to assist you and provide top-quality cleaning solutions for your home or business.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {contactOptions.map((option) => (
                <ContactCard title={option.title} description={option.description}>
                    {option.type === "email" || option.type === "tel" ? (
                        <a href={option.href} class="hover:underline">
                            {option.value}
                        </a>
                    ) : option.type === "button" ? (
                        <button class="font-medium text-white hover:text-white relative inline-block px-6 py-3 bg-[var(--primary)] hover:bg-[var(--primary-hover)] rounded-full transition-all duration-300 hover:-translate-y-1 overflow-hidden cursor-pointer hover:cursor-pointer">
                            <span class="relative z-10 flex items-center gap-2">
                                <Icon name="bounding-box" class="icon w-4 h-4" />
                                {option.text}
                            </span>
                        </button>
                    ) : null}
                </ContactCard>
            ))}
        </div>
    </div>
</section>
