---
import ProcessCard from "./ProcessCard.astro";
import ProcessStep from "./ProcessStep.astro";
import SectionHeader from "@components/base/SectionHeader.astro";

const cardsData = [
    {
        title: "Lorem ipsum dolor",
        text: "Sit amet consectetur. Nulla velit dignissim sed ornare vulputate. Lectus vitae tincidunt posuere sem nisi est.",
    },
    {
        title: "Lorem ipsum dolor sit",
        text: "Nulla velit dignissim sed ornare vulputate. Ultrices volutpat non tellus mauris ut nisi tortor vestibulum amet. Lectus vitae tincidunt posuere sem nisi est. Velit imperdiet urna vulputate in diam neque.",
    },
];

const stepsData = [
    {
        number: "1",
        title: "Book",
        description: "Online in 60 seconds or by phone.",
    },
    {
        number: "2",
        title: "We clean",
        description: "Trained, background-checked pros.",
    },
    {
        number: "3",
        title: "Relax",
        description: "100% satisfaction guaranteed.",
    },
];

const sectionTitle = "CLEANING PROCESS";
const sectionSubtitle = "How It Works";
const sectionDescription = "";
---

<section class="section-how-it-works section-gap">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-16 xl:gap-24">
            <!-- Левая колонка с текстом и шагами -->
            <div class="flex flex-col">
                <div class="mb-xl">
                    <SectionHeader 
                        title={sectionSubtitle} 
                        subtitle={''} 
                        description={sectionDescription}
                        category={sectionTitle}
                    />
                </div>

                <!-- Блок с двумя карточками (позиционируются абсолютно) -->
                <div class="relative h-64 md:h-56 mb-xl hidden lg:block">
                    <ProcessCard
                            title={cardsData[0].title}
                            text={cardsData[0].text}
                            className="absolute top-0 left-0 w-4/5 transform -rotate-3"
                    />
                    <ProcessCard
                            title={cardsData[1].title}
                            text={cardsData[1].text}
                            className="absolute bottom-0 right-0 w-4/5 transform rotate-2 z-10"
                    />
                </div>

                <!-- Список шагов -->
                <div class="mt-auto">
                    {stepsData.map((step) => <ProcessStep {...step} />)}
                </div>
            </div>

            <!-- Правая колонка с изображением -->
            <div class="hidden lg:flex items-center justify-center bg-teal-50/70 rounded-3xl p-8">
                <div class="w-full h-full bg-gray-300 rounded-2xl flex items-center justify-center">
                    <!-- Placeholder иконка изображения -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image">
                        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>
