---
import { Image } from 'astro:assets';
import ProcessCard from "./ProcessCard.astro";
import ProcessStep from "./ProcessStep.astro";
import SectionHeader from "@components/base/SectionHeader.astro";
import howItWorksImage from '@assets/how/howItWorl.png';

const cardsData = [
    {
        title: "Professional Cleaning Services",
        text: "Our trained professionals use eco-friendly products and state-of-the-art equipment to deliver exceptional cleaning results that exceed your expectations.",
    },
    {
        title: "Quality Guarantee",
        text: "We stand behind our work with a 100% satisfaction guarantee. If you're not happy with our service, we'll make it right at no additional cost.",
    },
];

const stepsData = [
    {
        number: "1",
        title: "Book",
        description: "Online in 60 seconds or by phone.",
    },
    {
        number: "2",
        title: "We clean",
        description: "Trained, background-checked pros.",
    },
    {
        number: "3",
        title: "Relax",
        description: "100% satisfaction guaranteed.",
    },
];

const sectionTitle = "CLEANING PROCESS";
const sectionSubtitle = "How It Works";
const sectionDescription = "";
---

<section class="section-how-it-works section-gap">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:gap-16 xl:gap-24">
            <!-- Левая колонка с текстом и шагами -->
            <div class="flex flex-col">
                <div class="mb-xl">
                    <SectionHeader 
                        title={sectionSubtitle} 
                        subtitle={''} 
                        description={sectionDescription}
                        category={sectionTitle}
                    />
                </div>

                <!-- Блок с двумя карточками (позиционируются абсолютно) -->
                <div class="relative h-64 md:h-56 mb-xl hidden lg:block">
                    <ProcessCard
                            title={cardsData[0].title}
                            text={cardsData[0].text}
                            className="absolute top-0 left-0 w-4/5 transform -rotate-3 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 hover:rotate-0 hover:z-20"
                    />
                    <ProcessCard
                            title={cardsData[1].title}
                            text={cardsData[1].text}
                            className="absolute bottom-0 right-0 w-4/5 transform rotate-2 z-10 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 hover:rotate-0 hover:z-20"
                    />
                </div>

                <!-- Список шагов -->
                <div class="mt-auto">
                    {stepsData.map((step) => <ProcessStep {...step} />)}
                </div>
            </div>

            <!-- Правая колонка с изображением -->
            <div class="hidden lg:flex items-center justify-center bg-teal-50/70 rounded-3xl p-0 overflow-hidden">
                <Image
                    src={howItWorksImage}
                    alt="Cleaning process"
                    class="w-full h-full object-cover"
                    style="min-height: 400px;"
                    loading="lazy"
                    decoding="async"
                    quality={80}
                    format="avif"
                />
            </div>
        </div>
    </div>
</section>
