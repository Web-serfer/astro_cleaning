---
import { Image } from 'astro:assets';
import spongeImg from '@assets/hero/sponge.png';
import heroBg from '@assets/hero/hero.png';
import Tag from './Tag.astro';
import RatingCard from './RatingCard.astro';
import ServiceCard from './ServiceCard.astro';
import { heroData } from './heroData';
---

<!-- hero section -->
<section aria-labelledby="hero-heading" class="section-hero">
    <div class="container-sm">
        <div class="relative rounded-3xl p-8 sm:p-10 overflow-hidden" style="min-height: 500px;">
            <Image
                src={heroBg}
                alt="Hero Background"
                class="absolute inset-0 w-full h-full object-cover z-0"
            />
            <!-- темная подложка -->
            <div class="absolute inset-0 bg-black/50 z-10"></div>
            <div class="relative z-20">
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-end">

                    <!-- Левая колонка -->
                    <div class="lg:col-span-3 flex flex-col items-center text-center lg:items-start lg:text-left md:pb-12">
                        <Tag text={heroData.tag.text} />
                        <h1 id="hero-heading" class="text-2xl sm:text-4xl lg:text-5xl font-bold text-white v-gap-md leading-tight max-w-lg">
                            {heroData.heading.title}
                            <span
                                class="inline-flex justify-end items-baseline ml-4 bg-white rounded-full shadow"
                                style="min-width: 80px; height: 32px; padding: 0 0 2px 16px;"
                            >
                                <Image src={spongeImg} alt="Sponge" class="h-8 w-auto" style="margin: 0;" />
                            </span>
                            <br /> {heroData.heading.highlight}
                        </h1>
                    </div>

                    <!-- Правая колонка -->
                    <div class="lg:col-span-2 flex flex-col gap-8 w-full items-end">
                        <div class="w-[384px] max-w-none mr-8">
                            <RatingCard />
                        </div>
                        <div class="w-[384px] max-w-none mr-8">
                            <ServiceCard />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- services cards -->
<section aria-labelledby="services-heading" class="px-6 mt-8">
    <div class="container-sm">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {heroData.servicesCards.map(card => (
                <div
                    class="
                        font-sans rounded-3xl p-6 py-xl min-h-[220px]
                        flex flex-col justify-center items-center text-center
                        transition-transform duration-200 ease-in-out hover:-translate-y-1
                        w-[296px] mx-auto
                    "
                    style={`background-color: ${card.bgColor}; color: ${card.textColor};`}
                >
                    {card.isIconCard && (
                        <svg class="w-16 h-16 text-[#aebbb9]" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21 3H3C1.89543 3 1 3.89543 1 5V19C1 20.1046 1.89543 21 3 21H21C22.1046 21 23 20.1046 23 19V5C23 3.89543 22.1046 3 21 3Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M8.5 8C9.32843 8 10 7.32843 10 6.5C10 5.67157 9.32843 5 8.5 5C7.67157 5 7 5.67157 7 6.5C7 7.32843 7.67157 8 8.5 8Z" fill="currentColor"/>
                            <path d="M23 16L17.5 12L7 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    )}

                    {card.title && (
                        <h3
                            class="text-[1.75rem] leading-[1.2] font-medium"
                            set:html={card.title}
                        />
                    )}
                    {card.subtitle && (
                        <p class="mt-sm text-[0.8rem] font-medium uppercase tracking-wider">
                            {card.subtitle}
                        </p>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>
