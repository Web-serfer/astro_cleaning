---
import { Image } from 'astro:assets';
import spongeImg from '@assets/hero/sponge.png';
import heroBg from '@assets/hero/hero.png';
import Tag from './Tag.astro';
import RatingCard from './RatingCard.astro';
import ServiceCard from './ServiceCard.astro';

---

<section class="py-10 px-4 sm:px-6 lg:px-8 font-sans">
    <div class="container">
        <div class="relative rounded-3xl p-8 sm:p-10 overflow-hidden" style="min-height: 500px;">
            <Image
                src={heroBg}
                alt="Hero Background"
                class="absolute inset-0 w-full h-full object-cover z-0"
            />
            <!-- темная подложка -->
            <div class="absolute inset-0 bg-black/50 z-10"></div>
            <div class="relative z-20">
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-end">

                    <!-- Левая колонка -->
                    <div class="lg:col-span-3 flex flex-col items-center text-center lg:items-start lg:text-left pb-12">
                        <Tag text="BEST CLEANING" />
                        <h1 class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-bold text-white my-5 leading-tight max-w-lg">
                            Top Quality
                            <span
                                class="inline-flex justify-end items-baseline ml-2 sm:ml-4 bg-white rounded-full shadow"
                                style="min-width: 60px; height: 24px; padding: 0 0 2px 12px;"
                            >
                                <Image src={spongeImg} alt="Sponge" class="h-6 w-auto sm:h-8" style="margin: 0;" />
                            </span>
                            <br /> Professional Cleaning
                        </h1>
                    </div>

                    <!-- Правая колонка -->
                    <div class="lg:col-span-2 flex flex-col gap-6 w-full items-center">
                        <div class="w-full max-w-sm">
                            <RatingCard />
                        </div>
                        <div class="w-full max-w-sm">
                            <ServiceCard />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
