---
import { Icon } from 'astro-icon/components';

const starCount = 5;
---

<article class="bg-white rounded-2xl p-6 shadow-lg transition-all duration-300 hover:shadow-xl hover:-translate-y-1" aria-label="Отзывы и рейтинги">
    <div class="text-2xl tracking-widest flex gap-1" aria-label="Рейтинг 5 звезд из 5">
        {Array.from({ length: starCount }, (_, index) => (
            <Icon 
                key={index}
                name="starIcon" 
                class="icon" 
                style="color: var(--primary);"
                aria-hidden="true"
            />
        ))}
    </div>
    <p class="text-gray-600 text-sm mt-2 mb-4">
        Rated 5.0/5.0 by Philly neighbors
    </p>
    <div class="flex items-center gap-5 text-dark-text font-bold text-xl">
        <div class="flex items-center gap-0">
            <Icon name="torchIcon" class="w-6 h-6" aria-hidden="true" />
            <span>BBB</span>
        </div>
        <span>yelp*</span>
        <span>Google</span>
    </div>
</article>
