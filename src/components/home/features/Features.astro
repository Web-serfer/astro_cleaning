---
import Card from './Card.astro';

const cardsData = [
    {
        title: "Eco-friendly<br>products",
        subtitle: "SAFE FOR KIDS & PETS",
        bgColor: "#f3f1f8",
        textColor: "#1f1f1f",
    },
    {
        bgColor: "#e1efed",
        isIconCard: true,
    },
    {
        title: "Affordable, upfront<br>pricing",
        subtitle: "NO SURPRISES, EVER",
        bgColor: "#f3f1f8",
        textColor: "#1f1f1f",
    },
    {
        title: "Insured & 100%<br>guaranteed",
        subtitle: "WE MAKE IT RIGHT",
        bgColor: "#6ca19a",
        textColor: "#ffffff",
    }
];

// SVG-иконка осталась без изменений
const placeholderIconSVG = `
<svg class="w-16 h-16 text-[#aebbb9]" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M21 3H3C1.89543 3 1 3.89543 1 5V19C1 20.1046 1.89543 21 3 21H21C22.1046 21 23 20.1046 23 19V5C23 3.89543 22.1046 3 21 3Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M8.5 8C9.32843 8 10 7.32843 10 6.5C10 5.67157 9.32843 5 8.5 5C7.67157 5 7 5.67157 7 6.5C7 7.32843 7.67157 8 8.5 8Z" fill="currentColor"/>
  <path d="M23 16L17.5 12L7 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
`;
---

<section class="bg-white px-6">
    <div class="container">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {cardsData.map(card => (
                    <Card
                            title={card.title}
                            subtitle={card.subtitle}
                            bgColor={card.bgColor}
                            textColor={card.textColor}
                    >
                        {card.isIconCard && <Fragment set:html={placeholderIconSVG} />}
                    </Card>
            ))}
        </div>
    </div>
</section>
