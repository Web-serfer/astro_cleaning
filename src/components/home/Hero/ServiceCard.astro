---
import ButtonPrimary from './ButtonPrimary.astro';
import ButtonSecondary from './ButtonSecondary.astro';
---
<div class="bg-white rounded-2xl p-6 shadow-lg flex flex-col gap-4 h-full">
    <!-- Placeholder для картинки -->
    <div class="w-full h-36 bg-slate-200 rounded-xl"></div>

    <p class="text-gray-600 leading-relaxed">
        Lorem ipsum dolor sit amet consectetur. Tincidunt nisi amet ultrices aliquet ultrices. Viverra egestas.
    </p>

    <!-- mt-auto прижмет кнопки к низу карточки -->
    <div class="flex gap-3 mt-auto">
        <ButtonSecondary text="SERVICES" />
        <ButtonPrimary text="BOOK NOW" />
    </div>
</div>
