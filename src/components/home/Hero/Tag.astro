---
interface Props {
    text: string;
}
const { text } = Astro.props;
---
<div class="flex items-center gap-2">

    <div class="inline-flex items-center gap-2 border border-indigo-200 rounded-full py-1 px-3 text-xs text-primary font-medium">
        <div class="w-3 h-3 bg-[#5d3ebc] rounded-full"></div>
        {text}
    </div>
</div>