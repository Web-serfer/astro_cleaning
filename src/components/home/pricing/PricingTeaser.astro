---
import PricingCard from "./PricingCard.astro";
import SectionHeader from "@components/base/SectionHeader.astro";

const pricingData = [
    {
        tag: "Apartment",
        price: "~$159/h",
        description: "Studios & 1-2 BR",
    },
    {
        tag: "House",
        price: "~$159/h",
        description: "Townhomes & Single-Family",
    },
    {
        tag: "Move-Out",
        price: "~$199/h",
        description: "Empty units only",
    },
];

const sectionTitle = "Pricing";
const sectionSubtitle = "Pricing Teaser??";
const sectionDescription = "Our transparent pricing ensures you know exactly what you're paying for. Choose from our range of cleaning services tailored to your needs, with no hidden fees.";
---

<section class="section-pricing section-gap">
    <div class="container mx-auto px-4">
        <div class="mb-xl">
            <SectionHeader 
                title={sectionSubtitle} 
                subtitle={''} 
                description={sectionDescription}
                category={sectionTitle}
                allLink="/pricing"
                allLinkText="MORE ABOUT PRICING"
            />
        </div>

        <!-- Сетка с карточками цен -->
        <div class="mt-xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {pricingData.map(card => <PricingCard {...card} />)}
        </div>

        <!-- Футер секции -->
        <div class="text-center mt-xl">
            <p class="text-gray-600 mb-lg">
                Prices vary by size/condition. Get your exact price instantly.
            </p>
            <button
                onclick="openModal()"
                class="font-medium text-white hover:text-white relative inline-flex items-center justify-center px-8 py-4 bg-[var(--primary)] hover:bg-[var(--primary-hover)] rounded-full transition-all duration-300 hover:-translate-y-1 overflow-hidden cursor-pointer hover:cursor-pointer shadow-lg hover:shadow-xl"
            >
                <span class="relative z-10 flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                        <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>
                    </svg>
                    BOOK NOW
                </span>
            </button>
        </div>
    </div>
</section>