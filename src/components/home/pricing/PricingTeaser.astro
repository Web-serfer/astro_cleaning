---
import PricingCard from "./PricingCard.astro";
import SectionHeader from "@components/base/SectionHeader.astro";
import { Icon } from 'astro-icon/components';

const pricingData = [
    {
        tag: "Apartment",
        price: "~$159/h",
        description: "Studios & 1-2 BR",
    },
    {
        tag: "House",
        price: "~$159/h",
        description: "Townhomes & Single-Family",
    },
    {
        tag: "Move-Out",
        price: "~$199/h",
        description: "Empty units only",
    },
];

const sectionTitle = "Pricing";
const sectionSubtitle = "Pricing Teaser??";
const sectionDescription = "Our transparent pricing ensures you know exactly what you're paying for. Choose from our range of cleaning services tailored to your needs, with no hidden fees.";
---

<section class="section section-gap bg-pricing">
    <div class="container mx-auto px-4">
        <div class="mb-xl">
            <SectionHeader 
                title={sectionSubtitle} 
                subtitle={''} 
                description={sectionDescription}
                category={sectionTitle}
                allLink="/pricing"
                allLinkText="MORE ABOUT PRICING"
            />
        </div>

        <!-- Сетка с карточками цен -->
        <div class="mt-xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {pricingData.map(card => <PricingCard {...card} />)}
        </div>

        <!-- Футер секции -->
        <div class="text-center mt-xl">
            <p class="text-gray-600 mb-lg">
                Prices vary by size/condition. Get your exact price instantly.
            </p>
            <button
                onclick="openModal()"
                class="font-medium text-white hover:text-white relative inline-block px-6 py-3 bg-[var(--primary)] hover:bg-[var(--primary-hover)] rounded-full transition-all duration-300 hover:-translate-y-1 overflow-hidden cursor-pointer hover:cursor-pointer"
            >
                <span class="relative z-10 flex items-center gap-2">
                    <Icon name="bounding-box" class="icon w-4 h-4" />
                    BOOK NOW
                </span>
            </button>
        </div>
    </div>
</section>