---
import Layout from "@layouts/Layout.astro";

import Hero from "@components/home/hero/Hero.astro";
import Features from "@components/home/features/Features.astro";
import Services from "@components/home/services/Services.astro";

const pageTitle = 'Home';
const pageDescription = 'Professional cleaning services for your home and office. Get a free quote today.';
const pageCanonical = 'https://example.com/tip';
---

<Layout title={pageTitle} description={pageDescription} canonical={pageCanonical}>
  <Hero />
  <Features />
  <Services />
</Layout>
