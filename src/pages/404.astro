---
import "@styles/global.css";

const pageTitle = 'Page Not Found';
const pageDescription = 'Sorry, the page you are looking for does not exist.';
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription}>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="antialiased font-sans">

<main class="relative min-h-screen flex items-center justify-center overflow-hidden p-4">
    <!-- Decorative animated background -->
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 via-white to-sky-100 -z-10"></div>
    <div class="absolute top-0 left-0 w-72 h-72 bg-purple-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
    <div class="absolute top-0 right-1/4 w-72 h-72 bg-sky-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
    <div class="absolute bottom-0 left-1/3 w-72 h-72 bg-pink-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>

    <div class="w-full max-w-4xl mx-auto text-center animate-fade-in-up">
        <!-- Main content -->
        <div class="mb-8">
            <h1 class="text-8xl md:text-9xl font-black bg-gradient-to-r from-purple-600 to-sky-500 bg-clip-text text-transparent mb-4 animate-float">
                404
            </h1>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-4">Oops! It looks like you're lost.</h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
                The page you're looking for might have been removed, had its name changed, or is temporarily unavailable.
            </p>
        </div>

        <!-- "Go Home" Button -->
        <div class="mt-10">
            <a
                    href="/"
                    class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[var(--primary)] text-white font-semibold rounded-full shadow-lg shadow-purple-500/30 transition-all duration-300 ease-in-out hover:bg-[var(--primary-hover)] hover:-translate-y-1 hover:shadow-xl hover:shadow-purple-500/50 focus:outline-none focus:ring-4 focus:ring-purple-300"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                <span>Return to Homepage</span>
            </a>
        </div>

        <!-- Helpful info cards -->
        <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
            <div class="bg-white/60 backdrop-blur-lg p-6 rounded-2xl border border-white/30 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-white hover:-translate-y-1">
                <h3 class="font-bold text-lg mb-2 text-[var(--primary)]">Quick Links</h3>
                <ul class="space-y-1">
                    <li><a href="/services" class="text-gray-700 hover:text-[var(--primary)] transition-colors">Our Services</a></li>
                    <li><a href="/about" class="text-gray-700 hover:text-[var(--primary)] transition-colors">About Us</a></li>
                    <li><a href="/contact" class="text-gray-700 hover:text-[var(--primary)] transition-colors">Contact Us</a></li>
                </ul>
            </div>

            <div class="bg-white/60 backdrop-blur-lg p-6 rounded-2xl border border-white/30 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-white hover:-translate-y-1">
                <h3 class="font-bold text-lg mb-2 text-[var(--primary)]">Need Help?</h3>
                <p class="text-gray-700 mb-2">Our team is ready to help.</p>
                <p class="text-lg font-semibold text-slate-800">(215) 555-0199</p>
            </div>

            <div class="bg-white/60 backdrop-blur-lg p-6 rounded-2xl border border-white/30 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-white hover:-translate-y-1">
                <h3 class="font-bold text-lg mb-2 text-[var(--primary)]">Email Us</h3>
                <a href="mailto:info@wellknowncleaning.com" class="text-gray-700 hover:text-[var(--primary)] transition-colors">info@wellknowncleaning.com</a>
                <p class="text-sm text-gray-500 mt-2">We reply within 24 hours.</p>
            </div>
        </div>
    </div>
</main>

<footer class="absolute bottom-0 w-full py-4 text-center text-gray-500 text-sm">
    <p>&copy;{new Date().getFullYear()} WellKnown Cleaning. All rights reserved.</p>
</footer>


</body>
</html>

<style>
    :root {
        --primary: #6d28d9;
        --primary-hover: #5b21b6;
    }
    body {

        font-family: 'Inter', sans-serif;
    }
</style>