---
import Layout from "@layouts/Layout.astro";

const pageTitle = 'Page Not Found';
const pageDescription = 'Sorry, the page you are looking for does not exist.';
const pageCanonical = 'https://www.wellknowncleaning.com/404';
---

<Layout title={pageTitle} description={pageDescription} canonical={pageCanonical}>
  <div class="flex flex-col items-center justify-center text-center py-20 px-4">
    <h1 class="text-6xl font-bold text-gray-800 mb-4">404</h1>
    <h2 class="text-3xl font-semibold text-gray-700 mb-6">Page Not Found</h2>
    <p class="text-lg text-gray-600 max-w-md mb-8">
      Sorry, the page you are looking for might have been removed, had its name changed, 
      or is temporarily unavailable.
    </p>
    <a 
      href="/" 
      class="font-medium text-white hover:text-white relative inline-block px-8 py-4 bg-[var(--primary)] hover:bg-[var(--primary-hover)] rounded-full transition-all duration-300 hover:-translate-y-1 overflow-hidden cursor-pointer hover:cursor-pointer"
    >
      <span class="relative z-10">Go Back Home</span>
    </a>
  </div>
</Layout>